# MyApp build config

[project]
name    = MyApp
version = 1.0
output  = bin/MyApp

[compiler]
fbc  = fbc

[sources]
src/main.bas
src/utils.bas
src/graphics.bas

[includes]
include/
vendor/include/
vendor/SDL/

[libs]
libs/mylib.a

[links]
m
GL

[targets]
debug   = -g -w all -exx
release = -w all -O 2
test    = -w all -g -exx -d TESTING

[hooks]
pre_build  = echo "Building..."
post_build = strip bin/MyApp
