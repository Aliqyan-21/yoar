RELEASE_FLAGS = -w all -O 2
OUTPUT = bin/yoar

debug: ${SOURCES}
	mkdir -p bin
	${CC} ${DEBUG_FLAGS} ${SOURCES} ${INCLUDES} ${LIBS} ${LFLAGS} -x ${OUTPUT}
release: ${SOURCES}
	mkdir -p bin
	${CC} ${RELEASE_FLAGS} ${SOURCES} ${INCLUDES} ${LIBS} ${LFLAGS} -x ${OUTPUT}

clean:
	rm bin/yoar

run:
	./bin/yoar
